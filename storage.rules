rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Presupuestos: readable by anyone (for public share links),
    // writable only by authenticated users.
    match /presupuestos/{fileName=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Everything else: auth required
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
